<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
  <meta name="theme-color" content="#FFF5EE">

  {%- if page_description -%}
    <meta name="description" content="{{ page_description | escape }}">
  {%- elsif template == 'index' -%}
    <meta name="description" content="{{ shop.description | default: 'Nonprofit arts education for children — dance, music, theater, and visual art in Queens, NY.' | escape }}">
  {%- endif -%}

  {% render 'meta-tags' %}
  {% render 'json-ld' %}

  <title>
    {%- if template == 'index' -%}
      {{ shop.name }}
    {%- elsif page_title -%}
      {{ page_title }} &mdash; {{ shop.name }}
    {%- else -%}
      {{ shop.name }}
    {%- endif -%}
  </title>

  <link rel="canonical" href="{{ canonical_url }}">

  <link rel="icon" type="image/png" sizes="32x32" href="{{ 'favicon-32.png' | asset_url }}">
  <link rel="icon" type="image/png" sizes="16x16" href="{{ 'favicon-16.png' | asset_url }}">
  <link rel="apple-touch-icon" sizes="180x180" href="{{ 'favicon-180.png' | asset_url }}">

  <style>
    @font-face {
      font-family: "Voltra";
      src: url("{{ 'Voltra-Normal.ttf' | asset_url }}") format("truetype");
      font-weight: 400; font-style: normal; font-display: swap;
    }
    @font-face {
      font-family: "Chivo";
      src: url("{{ 'Chivo-Variable.ttf' | asset_url }}") format("truetype-variations"),
           url("{{ 'Chivo-Variable.ttf' | asset_url }}") format("truetype");
      font-weight: 100 900; font-style: normal; font-display: swap;
    }
    @font-face {
      font-family: "Chivo";
      src: url("{{ 'Chivo-Italic-Variable.ttf' | asset_url }}") format("truetype-variations"),
           url("{{ 'Chivo-Italic-Variable.ttf' | asset_url }}") format("truetype");
      font-weight: 100 900; font-style: italic; font-display: swap;
    }
    @font-face {
      font-family: "Phosphor";
      src: url("{{ 'Phosphor.woff2' | asset_url }}") format("woff2"),
           url("{{ 'Phosphor.woff' | asset_url }}") format("woff"),
           url("{{ 'Phosphor.ttf' | asset_url }}") format("truetype");
      font-weight: normal; font-style: normal; font-display: swap;
    }
  </style>

  <link rel="stylesheet" href="{{ 'design-system.css' | asset_url }}">
  <link rel="stylesheet" href="{{ 'auth-modal.css' | asset_url }}">
  <link rel="stylesheet" href="{{ 'phosphor.css' | asset_url }}">

  <script src="{{ 'auth-modal.js' | asset_url }}" defer></script>
  <script src="{{ 'site.js' | asset_url }}" defer></script>

  {{ content_for_header }}
</head>
<body class="template-{{ template | replace: '.', '-' }}">

  <a class="skip-link" href="#main">Skip to main content</a>

  {% section 'promo-bar' %}
  {% section 'header' %}

  <main id="main" tabindex="-1">
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}

</body>
</html>
