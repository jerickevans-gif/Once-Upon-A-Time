<section class="wrap" style="padding: var(--s-9) 0;">
  {%- if section.settings.eyebrow != blank -%}
    <span class="eyebrow" style="text-align: center; display: block; margin-bottom: var(--s-2);">{{ section.settings.eyebrow }}</span>
  {%- endif -%}
  {%- if section.settings.heading != blank -%}
    <h2 style="text-align: center; margin-bottom: var(--s-7);">{{ section.settings.heading }}</h2>
  {%- endif -%}
  <div class="who__features" style="display: grid; grid-template-columns: repeat({{ section.settings.columns }}, 1fr); gap: var(--s-5);">
    {%- for block in section.blocks -%}
      <div class="feature" {{ block.shopify_attributes }} style="display: grid; grid-template-columns: 36px 1fr; gap: var(--s-3); align-items: start;">
        <i class="ph {{ block.settings.icon | default: 'ph-sparkle' }}" aria-hidden="true"></i>
        <div>
          {%- if block.settings.title != blank -%}<h3 style="font-family: var(--sans); font-weight: 700; font-size: var(--t-base); margin: 0 0 4px;">{{ block.settings.title }}</h3>{%- endif -%}
          <p style="margin: 0; font-size: var(--t-base); color: var(--ink);">{{ block.settings.body }}</p>
        </div>
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Feature grid",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "range", "id": "columns", "label": "Columns", "min": 1, "max": 4, "step": 1, "default": 3 }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        { "type": "text", "id": "icon", "label": "Phosphor icon class", "default": "ph-hand-heart" },
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "textarea", "id": "body", "label": "Body" }
      ]
    }
  ],
  "presets": [
    { "name": "Feature grid",
      "blocks": [{ "type": "feature" }, { "type": "feature" }, { "type": "feature" }]
    }
  ]
}
{% endschema %}
