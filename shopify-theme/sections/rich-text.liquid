<section class="wrap" style="padding: var(--s-7) 0;">
  {%- if section.settings.eyebrow != blank -%}
    <span class="eyebrow">{{ section.settings.eyebrow }}</span>
  {%- endif -%}
  {%- if section.settings.heading != blank -%}
    <h2 style="text-align: {{ section.settings.text_align }};">{{ section.settings.heading }}</h2>
  {%- endif -%}
  <div class="rte" style="text-align: {{ section.settings.text_align }};">{{ section.settings.body }}</div>
</section>

{% schema %}
{
  "name": "Rich text",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "richtext", "id": "body", "label": "Body" },
    { "type": "select", "id": "text_align", "label": "Text alignment", "options": [{ "value": "left", "label": "Left" }, { "value": "center", "label": "Center" }], "default": "left" }
  ],
  "presets": [{ "name": "Rich text" }]
}
{% endschema %}
