<section class="hero">
  <div class="wrap hero__grid">
    <div class="hero__copy">
      {%- if section.settings.eyebrow != blank -%}
        <span class="hero__meta"><i class="ph ph-clock" aria-hidden="true"></i> {{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h1>{{ section.settings.heading | newline_to_br | default: 'Jazz Class — Winter 2026' }}</h1>
      <p class="hero__sub">{{ section.settings.subhead }}</p>
      <p class="hero__lede">{{ section.settings.lede }}</p>
      <div class="hero__actions">
        {%- if section.settings.cta1_label != blank -%}
          <a class="btn" href="{{ section.settings.cta1_url | default: '#' }}">
            {%- if section.settings.cta1_icon != blank -%}<i class="ph {{ section.settings.cta1_icon }}"></i>{%- endif -%}
            {{ section.settings.cta1_label }}
          </a>
        {%- endif -%}
        {%- if section.settings.cta2_label != blank -%}
          <a class="btn btn--garden" href="{{ section.settings.cta2_url | default: '#' }}">
            {%- if section.settings.cta2_icon != blank -%}<i class="ph {{ section.settings.cta2_icon }}"></i>{%- endif -%}
            {{ section.settings.cta2_label }}
          </a>
        {%- endif -%}
        {%- if section.settings.cta3_label != blank -%}
          <a class="btn btn--text" href="{{ section.settings.cta3_url | default: '#' }}">{{ section.settings.cta3_label }} <i class="ph ph-arrow-right"></i></a>
        {%- endif -%}
      </div>
    </div>
    {%- if section.settings.image != blank -%}
      <div class="hero__photo" role="img" aria-label="{{ section.settings.image_alt }}" style="background-image:url('{{ section.settings.image | image_url: width: 1200 }}')"></div>
    {%- else -%}
      <div class="hero__photo" role="img" aria-label="{{ section.settings.image_alt }}" style="background-image:url('{{ 'landing-jazz-hero.jpg' | asset_url }}')"></div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Hero card",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow chip", "default": "10 spots left" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Jazz Class — Winter 2026" },
    { "type": "text", "id": "subhead", "label": "Subhead", "default": "Thursdays | 4pm | Ages 10+ | Studio Room A" },
    { "type": "textarea", "id": "lede", "label": "Lede paragraph" },
    { "type": "text", "id": "cta1_label", "label": "Primary CTA label", "default": "Enroll Now" },
    { "type": "url", "id": "cta1_url", "label": "Primary CTA URL" },
    { "type": "text", "id": "cta1_icon", "label": "Primary CTA Phosphor icon", "default": "ph-ticket" },
    { "type": "text", "id": "cta2_label", "label": "Secondary CTA label", "default": "Add to Cart" },
    { "type": "url", "id": "cta2_url", "label": "Secondary CTA URL" },
    { "type": "text", "id": "cta2_icon", "label": "Secondary CTA Phosphor icon", "default": "ph-shopping-cart-simple" },
    { "type": "text", "id": "cta3_label", "label": "Tertiary text link label", "default": "Learn More" },
    { "type": "url", "id": "cta3_url", "label": "Tertiary text link URL" },
    { "type": "image_picker", "id": "image", "label": "Hero photo" },
    { "type": "text", "id": "image_alt", "label": "Hero photo alt text", "default": "Students performing a jazz routine on stage" }
  ],
  "presets": [{ "name": "Hero card" }]
}
{% endschema %}
