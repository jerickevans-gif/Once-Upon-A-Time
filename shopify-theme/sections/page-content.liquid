<article class="wrap" style="padding: var(--s-7) 0;">
  {%- if page.title != blank -%}
    <h1 style="text-align:center; margin-bottom: var(--s-5);">{{ page.title }}</h1>
  {%- endif -%}
  <div class="page-rte">
    {{ page.content }}
  </div>
</article>

{% schema %}
{
  "name": "Page content",
  "settings": []
}
{% endschema %}
