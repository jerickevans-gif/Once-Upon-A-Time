<section class="wrap" style="padding: var(--s-9) 0;">
  <h1 style="text-align: center; margin-bottom: var(--s-7);">Your Cart</h1>

  {%- if cart.item_count > 0 -%}
    <form action="{{ routes.cart_url }}" method="post" novalidate>
      <ul style="list-style: none; padding: 0; margin: 0; display: grid; gap: var(--s-4);">
        {%- for item in cart.items -%}
          <li style="display: grid; grid-template-columns: 96px 1fr auto; gap: var(--s-4); align-items: center; padding: var(--s-4); background: var(--snow); border-radius: var(--radius); box-shadow: var(--shadow-sm);">
            {%- if item.image -%}<img src="{{ item.image | image_url: width: 192 }}" alt="{{ item.product.title }}" width="96" height="96" style="border-radius: var(--radius-sm); object-fit: cover;">{%- endif -%}
            <div>
              <h3 style="font-size: var(--t-base); margin: 0 0 4px;">{{ item.product.title }}</h3>
              <p style="margin: 0; color: var(--ink-muted); font-size: var(--t-label);">{{ item.variant.title }}</p>
            </div>
            <div style="font-weight: 700;">{{ item.final_line_price | money }}</div>
          </li>
        {%- endfor -%}
      </ul>

      <div style="display: flex; justify-content: space-between; align-items: center; margin-top: var(--s-7); padding-top: var(--s-5); border-top: 1px solid var(--line);">
        <strong style="font-size: var(--t-h4);">Subtotal: {{ cart.total_price | money }}</strong>
        <button class="btn" type="submit" name="checkout">Checkout</button>
      </div>
    </form>
  {%- else -%}
    <p style="text-align: center; color: var(--ink-muted);">Your cart is empty.</p>
    <div style="text-align: center; margin-top: var(--s-5);">
      <a class="btn" href="{{ routes.root_url }}">Browse programs</a>
    </div>
  {%- endif -%}
</section>
