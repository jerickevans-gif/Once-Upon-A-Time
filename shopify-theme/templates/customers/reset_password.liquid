{% comment %}
  customers/reset_password.liquid — Reset link landing form
{% endcomment %}
{%- layout 'theme' -%}

<section class="wrap" style="max-width:480px;padding:80px 24px">
  <h1 style="font-family:var(--serif);font-size:42px;text-transform:uppercase;margin:0 0 8px">Set a new password</h1>
  <p style="color:var(--ink-muted);margin:0 0 32px">Choose a password you haven't used before.</p>
  {%- form 'reset_customer_password' -%}
    {%- if form.errors -%}<div class="form-errors" role="alert">{{ form.errors | default_errors }}</div>{%- endif -%}
    <label class="field" style="display:flex;flex-direction:column;gap:6px;margin-bottom:18px"><span style="font-size:14px;font-weight:500">New password</span><input class="input" type="password" name="customer[password]" required minlength="6"></label>
    <label class="field" style="display:flex;flex-direction:column;gap:6px"><span style="font-size:14px;font-weight:500">Confirm password</span><input class="input" type="password" name="customer[password_confirmation]" required minlength="6"></label>
    <button class="btn" type="submit" style="width:100%;margin-top:24px">Update password</button>
  {%- endform -%}
</section>
