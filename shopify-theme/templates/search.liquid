{% comment %}
  search.liquid — Site-wide search results
{% endcomment %}
{%- layout 'theme' -%}

<section class="page-hero">
  <div class="wrap">
    <div class="page-hero__eyebrow">Search</div>
    <h1 style="margin-bottom:24px">{{ search.results_count }} result{{ search.results_count | pluralize: '', 's' }} for "{{ search.terms }}"</h1>
    <form action="{{ routes.search_url }}" method="get" role="search" style="max-width:560px;margin:0 auto;display:flex;gap:8px">
      <input type="search" name="q" value="{{ search.terms }}" placeholder="Search" autofocus class="input" style="flex:1">
      <button class="btn" type="submit">Search</button>
    </form>
  </div>
</section>

<section class="wrap" style="padding:48px 0;max-width:780px">
  {%- if search.performed and search.results.size > 0 -%}
    {%- for item in search.results -%}
      <a href="{{ item.url }}" style="display:block;padding:18px 0;border-bottom:1px solid var(--line);text-decoration:none;color:inherit">
        <div style="font-family:var(--serif);font-size:18px;color:var(--pillar);margin-bottom:4px">{{ item.title }}</div>
        {%- if item.body -%}
          <div style="font-size:13px;color:var(--ink-muted)">{{ item.body | strip_html | truncatewords: 30 }}</div>
        {%- endif -%}
        <div style="font-size:12px;color:var(--rose-700);margin-top:6px">{{ item.url }}</div>
      </a>
    {%- endfor -%}

    {%- if paginate.pages > 1 -%}
      {{ paginate | default_pagination }}
    {%- endif -%}
  {%- else -%}
    <div class="empty-state">
      <div class="empty-state__icon"><i class="ph ph-magnifying-glass"></i></div>
      <div class="empty-state__title">No matches{% if search.terms %} for "{{ search.terms }}"{% endif %}</div>
      <p class="empty-state__body">Try a shorter or different search term, or browse the home page.</p>
      <div class="empty-state__actions">
        <a class="btn" href="/">Back to home</a>
        <a class="btn btn--ghost" href="/pages/contact">Ask us anything</a>
      </div>
    </div>
  {%- endif -%}
</section>
