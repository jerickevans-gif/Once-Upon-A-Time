{% comment %}
  blog.liquid — Blog index used for the Newsletter blog
{% endcomment %}
{%- layout 'theme' -%}

<section class="page-hero"><div class="wrap"><div class="page-hero__eyebrow">Newsletter</div><h1>{{ blog.title }}</h1></div></section>

<section class="wrap" style="padding:48px 0;display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:24px">
  {%- paginate blog.articles by 12 -%}
    {%- for article in blog.articles -%}
      <a href="{{ article.url }}" class="nl-card" style="background:var(--snow);border:1px solid var(--line);border-radius:14px;overflow:hidden;text-decoration:none;color:inherit">
        {%- if article.image -%}<div style="aspect-ratio:16/10;background-image:url({{ article.image | img_url: '600x' }});background-size:cover;background-position:center"></div>{%- endif -%}
        <div style="padding:18px 20px">
          <div style="font-family:var(--serif);font-size:18px;text-transform:uppercase;margin-bottom:4px">{{ article.title }}</div>
          <div style="font-size:12px;color:var(--ink-muted)">{{ article.author }} · {{ article.published_at | date: '%b %d, %Y' }}</div>
        </div>
      </a>
    {%- endfor -%}
    {{ paginate | default_pagination }}
  {%- endpaginate -%}
</section>
